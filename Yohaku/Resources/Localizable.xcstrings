    "notification.denied.message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اسمح بإشعارات Yohaku في تطبيق الإعدادات لتفعيل هذا الخيار."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlaube Mitteilungen für Yohaku in der App „Einstellungen“, um dies zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow notifications for Yohaku in the Settings app to turn this on."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite las notificaciones de Yohaku en la app Ajustes para activarlo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez les notifications de Yohaku dans l’app Réglages pour activer cette option."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इसे चालू करने के लिए सेटिंग्स ऐप में Yohaku की सूचनाओं की अनुमति दें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Izinkan notifikasi Yohaku di aplikasi Pengaturan untuk mengaktifkannya."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Consenti le notifiche di Yohaku nell’app Impostazioni per attivarle."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定アプリでYohakuの通知を許可すると、オンにできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 앱에서 Yohaku의 알림을 허용하면 켤 수 있습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sta meldingen voor Yohaku toe in de Instellingen-app om dit in te schakelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zezwól na powiadomienia Yohaku w aplikacji Ustawienia, aby to włączyć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Permita as notificações do Yohaku no app Ajustes para ativar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "อนุญาตการแจ้งเตือนของ Yohaku ในแอปการตั้งค่าเพื่อเปิดใช้งาน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunu açmak için Ayarlar uygulamasında Yohaku bildirimlerine izin verin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cho phép thông báo của Yohaku trong ứng dụng Cài đặt để bật tính năng này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在“设置”App 中允许 Yohaku 的通知后即可开启。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「設定」App 中允許 Yohaku 的通知後即可開啟。"
          }
        }
      }
    },
