    "privacy.body": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا يجمع Yohaku أي بيانات شخصية. كل ما تضعه يبقى على جهازك ولا يُرسل إلى أي مكان أبدًا. لا توجد حسابات ولا تحليلات ولا خدمات من جهات خارجية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku erhebt keinerlei personenbezogene Daten. Alles, was Sie platzieren, bleibt auf Ihrem Gerät und wird niemals übertragen. Es gibt keine Konten, keine Analysen und keine Dienste von Drittanbietern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku does not collect any personal data. Everything you place stays on your device and is never sent anywhere. There are no accounts, no analytics, and no third-party services."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku no recopila ningún dato personal. Todo lo que colocas permanece en tu dispositivo y nunca se envía a ninguna parte. No hay cuentas, ni analíticas, ni servicios de terceros."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku ne collecte aucune donnée personnelle. Tout ce que vous placez reste sur votre appareil et n'est jamais envoyé ailleurs. Il n'y a ni compte, ni statistiques, ni services tiers."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku कोई व्यक्तिगत डेटा एकत्र नहीं करता। आप जो कुछ भी रखते हैं वह आपके डिवाइस पर ही रहता है और कहीं नहीं भेजा जाता। कोई खाता, कोई एनालिटिक्स और कोई तृतीय-पक्ष सेवा नहीं है।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku tidak mengumpulkan data pribadi apa pun. Semua yang Anda tempatkan tetap berada di perangkat Anda dan tidak pernah dikirim ke mana pun. Tidak ada akun, analitik, atau layanan pihak ketiga."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku non raccoglie alcun dato personale. Tutto ciò che inserisci rimane sul tuo dispositivo e non viene mai inviato altrove. Non ci sono account, analisi né servizi di terze parti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohakuは個人情報を一切収集しません。置いた余白はすべて端末内にのみ保存され、外部に送信されることはありません。アカウント登録、アクセス解析、第三者サービスの利用もありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku는 어떠한 개인정보도 수집하지 않습니다. 놓은 여백은 모두 기기 안에만 저장되며 외부로 전송되지 않습니다. 계정, 분석 도구, 제3자 서비스도 없습니다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku verzamelt geen persoonlijke gegevens. Alles wat je plaatst blijft op je apparaat en wordt nooit ergens naartoe verstuurd. Er zijn geen accounts, geen analyses en geen diensten van derden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku nie zbiera żadnych danych osobowych. Wszystko, co umieszczasz, pozostaje na Twoim urządzeniu i nigdy nie jest nigdzie wysyłane. Nie ma kont, analityki ani usług zewnętrznych."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Yohaku não coleta nenhum dado pessoal. Tudo o que você coloca permanece no seu dispositivo e nunca é enviado a lugar nenhum. Não há contas, análises nem serviços de terceiros."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku ไม่เก็บข้อมูลส่วนบุคคลใด ๆ ทุกสิ่งที่คุณวางจะอยู่ในอุปกรณ์ของคุณเท่านั้นและไม่ถูกส่งไปที่ใดเลย ไม่มีบัญชี ไม่มีการวิเคราะห์ และไม่มีบริการจากบุคคลที่สาม"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku hiçbir kişisel veri toplamaz. Yerleştirdiğiniz her şey cihazınızda kalır ve hiçbir yere gönderilmez. Hesap, analiz veya üçüncü taraf hizmeti yoktur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku không thu thập bất kỳ dữ liệu cá nhân nào. Mọi thứ bạn đặt đều chỉ được lưu trên thiết bị của bạn và không bao giờ được gửi đi đâu. Không có tài khoản, không phân tích và không có dịch vụ bên thứ ba."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku 不收集任何个人数据。你放置的一切都只保存在你的设备上，绝不会被发送到任何地方。没有账户、没有数据分析，也没有第三方服务。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Yohaku 不會收集任何個人資料。你放置的一切都只保存在你的裝置上，絕不會被傳送到任何地方。沒有帳號、沒有資料分析，也沒有第三方服務。"
          }
        }
      }
    },
