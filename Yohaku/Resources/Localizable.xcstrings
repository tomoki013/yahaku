    "about.tagline": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضع مساحة، لا خططًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Platz für Leere, nicht für Pläne."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Place space, not plans."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca espacio, no planes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez du vide, pas des plans."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "योजनाएँ नहीं, खाली जगह रखें।"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tempatkan ruang, bukan rencana."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Metti spazio, non impegni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予定ではなく、余白を置く。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일정이 아닌 여백을 놓다."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Plaats ruimte, geen plannen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Umieszczaj przestrzeń, nie plany."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloque espaço, não planos."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "วางพื้นที่ว่าง ไม่ใช่แผน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Plan değil, boşluk yerleştirin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đặt khoảng trống, không phải kế hoạch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
